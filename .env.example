# Set these as environment variables before launching, e.g.
#   set -a; source .env; set +a
# Nothing auto-loads a .env file. Never commit your real values.

# Image backend: null | diffusers | hf-api
NOVA_BACKEND=diffusers
NOVA_DIFFUSION_MODEL=stabilityai/sd-turbo

# Required only for NOVA_BACKEND=hf-api (create at https://huggingface.co/settings/tokens)
HF_TOKEN=

# Optional: full affect lexicon TSV (word<TAB>valence<TAB>arousal)
# Warriner norms: `python scripts/download_lexicon.py`
NOVAVISION_LEXICON=

# --- Serving / hardening (server.py) ---
# Bind is 127.0.0.1 by default. Set NOVA_PUBLIC=1 to bind 0.0.0.0 (expose publicly).
NOVA_PUBLIC=
# Require this bearer token on /api/generate when set (strongly recommended for public binds).
NOVA_API_TOKEN=
# Per-IP requests/minute and max concurrent generations.
NOVA_RATE_LIMIT=30
NOVA_MAX_CONCURRENCY=2
# Set only when behind a reverse proxy: trust X-Forwarded-For for the rate-limit key.
# Leave empty for direct exposure (else the header is spoofable to bypass the limit).
NOVA_TRUST_PROXY=
PORT=
# Comma-separated allowed cross-origin domains (empty = same-origin only)
CORS_ORIGINS=
