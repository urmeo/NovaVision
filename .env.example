# Copy to .env and fill in your values. Never commit your real .env.

# Image backend: null | diffusers | hf-api
BACKEND=diffusers
DIFFUSION_MODEL=stabilityai/sd-turbo

# Required only for BACKEND=hf-api (create one at https://huggingface.co/settings/tokens)
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN

# Optional: path to a full affect lexicon TSV (word<TAB>valence<TAB>arousal)
NOVAVISION_LEXICON=/path/to/your_lexicon.tsv

# Optional server hardening
HOST=127.0.0.1
PORT=8000
# Comma-separated allowed cross-origin domains (empty = same-origin only)
CORS_ORIGINS=
